<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Auberge de Grandeur — Welcome</title>
  <link rel="stylesheet" href="frontend/css/style.css" />
  <style>
    body { overflow: hidden; height: 100vh; }
    .auth-page { display: flex; height: 100vh; width: 100%; }

    .auth-left {
      flex: 1; position: relative; overflow: hidden;
      display: flex; flex-direction: column; justify-content: flex-end; padding: 48px;
    }
    .auth-bg {
      position: absolute; inset: 0;
      background: linear-gradient(160deg, var(--brown-dark) 0%, var(--brown-mid) 40%, var(--brown-rich) 100%);
      z-index: 0;
    }
    .arch-frames {
      position: absolute; top: 50%; left: 50%;
      transform: translate(-50%, -55%);
      display: flex; gap: 16px; z-index: 1;
    }
    .arch {
      width: 160px; height: 240px; border-radius: 100px 100px 0 0;
      overflow: hidden; border: 2px solid rgba(201,168,76,0.25);
      background: rgba(201,168,76,0.06); backdrop-filter: blur(2px);
      display: flex; align-items: center; justify-content: center;
    }
    .arch-label {
      font-family: var(--font-display); font-size: 0.85rem;
      color: rgba(245,230,200,0.4); letter-spacing: 0.08em;
      text-align: center; padding: 12px; line-height: 1.4;
    }
    .auth-left-content { position: relative; z-index: 2; }
    .hotel-name {
      font-family: var(--font-display); font-size: 3rem; font-weight: 300;
      color: var(--gold-light); letter-spacing: 0.04em; line-height: 1.1; margin-bottom: 12px;
    }
    .hotel-tagline {
      font-size: 0.82rem; color: rgba(245,230,200,0.55);
      letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 8px;
    }
    .contact-info {
      display: flex; align-items: center; gap: 8px;
      font-size: 0.78rem; color: rgba(245,230,200,0.45); margin-bottom: 20px;
    }
    .social-section-label {
      font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase;
      color: rgba(245,230,200,0.3); margin-bottom: 10px;
    }
    .social-links { display: flex; gap: 10px; }
    .social-btn {
      width: 38px; height: 38px; border-radius: 50%;
      border: 1.5px solid rgba(201,168,76,0.3);
      background: rgba(201,168,76,0.07);
      display: flex; align-items: center; justify-content: center;
      transition: var(--transition); cursor: pointer; text-decoration: none;
    }
    .social-btn:hover {
      background: var(--gold); border-color: var(--gold);
      transform: translateY(-2px); box-shadow: 0 4px 16px rgba(201,168,76,0.3);
    }
    .social-btn svg { width: 16px; height: 16px; transition: var(--transition); }
    .social-btn .stroke-icon { fill: none; stroke: var(--gold); stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
    .social-btn:hover .stroke-icon { stroke: var(--brown-dark); }
    .social-btn .fill-icon { fill: var(--gold); stroke: none; }
    .social-btn:hover .fill-icon { fill: var(--brown-dark); }

    .auth-right {
      width: 460px; background: var(--off-white);
      display: flex; flex-direction: column; overflow-y: auto;
    }
    .auth-panel {
      flex: 1; padding: 48px 44px;
      display: flex; flex-direction: column; justify-content: center;
    }
    .logo-mark {
      width: 44px; height: 44px;
      background: linear-gradient(135deg, var(--gold), var(--brown-light));
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      font-family: var(--font-display); font-size: 1.2rem;
      color: var(--brown-dark); font-weight: 600; margin-bottom: 20px;
    }
    .auth-tabs {
      display: flex; margin-bottom: 32px; border-bottom: 2px solid #e8ddd4;
    }
    .auth-tab {
      flex: 1; padding: 12px; text-align: center;
      font-size: 0.78rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--text-muted); cursor: pointer;
      border-bottom: 2px solid transparent; margin-bottom: -2px;
      transition: var(--transition); background: none;
    }
    .auth-tab.active { color: var(--brown-dark); border-bottom-color: var(--gold); }
    .auth-form { display: none; }
    .auth-form.active { display: block; }
    .auth-title {
      font-family: var(--font-display); font-size: 2rem; font-weight: 400;
      color: var(--brown-dark); margin-bottom: 4px;
    }
    .auth-subtitle { font-size: 0.82rem; color: var(--text-muted); margin-bottom: 24px; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

    .input-wrap { position: relative; }
    .input-wrap .form-control { padding-right: 44px; }
    .pw-toggle {
      position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
      background: none; border: none; cursor: pointer; padding: 4px;
      color: var(--text-muted); display: flex; align-items: center; transition: var(--transition);
    }
    .pw-toggle:hover { color: var(--brown-dark); }
    .pw-toggle svg { width: 16px; height: 16px; fill: none; stroke: currentColor; stroke-width: 2; stroke-linecap: round; }

    .form-control.input-error { border-color: #c0392b; box-shadow: 0 0 0 3px rgba(192,57,43,0.1); }

    .divider-text { text-align: center; position: relative; margin: 18px 0; }
    .divider-text::before, .divider-text::after {
      content: ''; position: absolute; top: 50%; width: 42%; height: 1px; background: #e8ddd4;
    }
    .divider-text::before { left: 0; }
    .divider-text::after  { right: 0; }
    .divider-text span { font-size: 0.72rem; color: var(--text-muted); background: var(--off-white); padding: 0 10px; }

    @media (max-width: 768px) {
      .auth-left { display: none; }
      .auth-right { width: 100%; }
      body { overflow: auto; }
    }
  </style>
</head>
<body>
<div class="auth-page">

  <!-- Left: Branding -->
  <div class="auth-left">
    <div class="auth-bg"></div>
    <div class="arch-frames">
      <div class="arch"><div class="arch-label">Luxury Rooms</div></div>
      <div class="arch" style="height:280px;margin-top:-20px"><div class="arch-label">Grand Lobby</div></div>
      <div class="arch"><div class="arch-label">Fine Dining</div></div>
    </div>
    <div class="auth-left-content">
      <div class="contact-info">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11.5 19.79 19.79 0 01.1 2.82 2 2 0 012.11 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 8.09a16 16 0 006 6l.46-.46a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
        </svg>
        09103354758
      </div>
      <div class="hotel-name">Auberge<br><em>de Grandeur</em></div>
      <div class="hotel-tagline">Where Every Stay Becomes a Memory</div>
      <div class="social-section-label">Follow us on</div>
      <div class="social-links">
        <!-- Facebook -->
        <a class="social-btn" href="https://facebook.com" target="_blank" rel="noopener noreferrer" title="Facebook">
          <svg viewBox="0 0 24 24"><path class="stroke-icon" d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
        </a>
        <!-- TikTok -->
        <a class="social-btn" href="https://tiktok.com" target="_blank" rel="noopener noreferrer" title="TikTok">
          <svg viewBox="0 0 24 24"><path class="fill-icon" d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.27 8.27 0 004.84 1.55V6.79a4.85 4.85 0 01-1.07-.1z"/></svg>
        </a>
        <!-- X / Twitter -->
        <a class="social-btn" href="https://x.com" target="_blank" rel="noopener noreferrer" title="X (Twitter)">
          <svg viewBox="0 0 24 24"><path class="fill-icon" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <!-- Instagram -->
        <a class="social-btn" href="https://instagram.com" target="_blank" rel="noopener noreferrer" title="Instagram">
          <svg viewBox="0 0 24 24">
            <rect class="stroke-icon" x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path class="stroke-icon" d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
            <line class="stroke-icon" x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Right: Auth Forms -->
  <div class="auth-right">
    <div class="auth-panel">
      <div class="logo-mark">A</div>

      <div class="auth-tabs">
        <button class="auth-tab active" onclick="switchTab('login')">Log In</button>
        <button class="auth-tab" onclick="switchTab('register')">Register</button>
      </div>

      <!-- Login -->
      <div class="auth-form active" id="form-login">
        <div class="auth-title">Welcome back</div>
        <div class="auth-subtitle">Sign in to manage your reservations</div>

        <div class="form-group">
          <label>Username</label>
          <input type="text" class="form-control" id="login-username"
            placeholder="Enter your username" autocomplete="username" />
        </div>
        <div class="form-group">
          <label>Password</label>
          <div class="input-wrap">
            <input type="password" class="form-control" id="login-password"
              placeholder="Enter your password" autocomplete="current-password" />
            <button class="pw-toggle" type="button" onclick="togglePw('login-password', this)" tabindex="-1">
              <svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
        </div>

        <button class="btn btn-primary btn-full btn-lg mt-16" onclick="handleLogin()">Sign In</button>
        <div class="divider-text mt-16"><span>or</span></div>
        <button class="btn btn-outline btn-full" onclick="switchTab('register')">Create an Account</button>
      </div>

      <!-- Register -->
      <div class="auth-form" id="form-register">
        <div class="auth-title">Create account</div>
        <div class="auth-subtitle">Join Auberge de Grandeur today</div>

        <div class="form-row">
          <div class="form-group">
            <label>First Name</label>
            <input type="text" class="form-control" id="reg-firstname" placeholder="First name" autocomplete="given-name"/>
          </div>
          <div class="form-group">
            <label>Last Name</label>
            <input type="text" class="form-control" id="reg-lastname" placeholder="Last name" autocomplete="family-name"/>
          </div>
        </div>
        <div class="form-group">
          <label>Email Address</label>
          <input type="email" class="form-control" id="reg-email" placeholder="you@example.com" autocomplete="email"/>
        </div>
        <div class="form-group">
          <label>Phone Number</label>
          <input type="tel" class="form-control" id="reg-phone" placeholder="09XXXXXXXXX" autocomplete="tel"/>
        </div>
        <div class="form-group">
          <label>Username</label>
          <input type="text" class="form-control" id="reg-username" placeholder="Letters, numbers, underscore" autocomplete="username"/>
        </div>
        <div class="form-group">
          <label>Password</label>
          <div class="input-wrap">
            <input type="password" class="form-control" id="reg-password" placeholder="Minimum 6 characters" autocomplete="new-password"/>
            <button class="pw-toggle" type="button" onclick="togglePw('reg-password', this)" tabindex="-1">
              <svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
        </div>

        <button class="btn btn-primary btn-full btn-lg mt-8" onclick="handleRegister()">Create Account</button>
        <div class="divider-text mt-16"><span>or</span></div>
        <button class="btn btn-outline btn-full" onclick="switchTab('login')">Already have an account? Sign In</button>
      </div>

    </div>
  </div>
</div>

<script src="frontend/js/app.js"></script>
<script>
  if (Store.getCurrentUser()) {
    window.location.href = 'frontend/pages/dashboard.html';
  }

  function switchTab(tab) {
    document.querySelectorAll('.auth-tab').forEach((t, i) => {
      t.classList.toggle('active', (i === 0 && tab === 'login') || (i === 1 && tab === 'register'));
    });
    document.getElementById('form-login').classList.toggle('active', tab === 'login');
    document.getElementById('form-register').classList.toggle('active', tab === 'register');
    document.querySelectorAll('.form-control').forEach(el => el.classList.remove('input-error'));
  }

  function togglePw(id, btn) {
    const inp = document.getElementById(id);
    const show = inp.type === 'password';
    inp.type = show ? 'text' : 'password';
    btn.innerHTML = show
      ? `<svg viewBox="0 0 24 24"><path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>`
      : `<svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`;
  }

  function handleLogin() {
    document.querySelectorAll('.form-control').forEach(el => el.classList.remove('input-error'));
    const username = document.getElementById('login-username').value.trim();
    const password = document.getElementById('login-password').value;
    if (!username) { document.getElementById('login-username').classList.add('input-error'); UI.showToast('Please enter your username.', 'error'); return; }
    if (!password) { document.getElementById('login-password').classList.add('input-error'); UI.showToast('Please enter your password.', 'error'); return; }

    const result = Auth.login(username, password);
    if (result.success) {
      UI.showToast(`Welcome back, ${result.user.firstName}!`, 'success');
      setTimeout(() => { window.location.href = 'frontend/pages/dashboard.html'; }, 800);
    } else {
      document.getElementById('login-username').classList.add('input-error');
      document.getElementById('login-password').classList.add('input-error');
      UI.showToast(result.message, 'error');
    }
  }

  function handleRegister() {
    document.querySelectorAll('.form-control').forEach(el => el.classList.remove('input-error'));
    const fields = {
      firstName: document.getElementById('reg-firstname'),
      lastName:  document.getElementById('reg-lastname'),
      email:     document.getElementById('reg-email'),
      phone:     document.getElementById('reg-phone'),
      username:  document.getElementById('reg-username'),
      password:  document.getElementById('reg-password'),
    };

    for (const [k, el] of Object.entries(fields)) {
      if (!el.value.trim()) {
        el.classList.add('input-error');
        el.focus();
        UI.showToast('Please fill in all fields.', 'error'); return;
      }
    }
    if (!fields.email.value.includes('@') || !fields.email.value.includes('.')) {
      fields.email.classList.add('input-error');
      UI.showToast('Please enter a valid email address.', 'error'); return;
    }
    if (fields.password.value.length < 6) {
      fields.password.classList.add('input-error');
      UI.showToast('Password must be at least 6 characters.', 'error'); return;
    }
    if (!/^[a-zA-Z0-9_]+$/.test(fields.username.value.trim())) {
      fields.username.classList.add('input-error');
      UI.showToast('Username: letters, numbers, and underscores only.', 'error'); return;
    }

    const data = {
      firstName: fields.firstName.value.trim(),
      lastName:  fields.lastName.value.trim(),
      email:     fields.email.value.trim(),
      contactNumber: fields.phone.value.trim(),
      username:  fields.username.value.trim(),
      password:  fields.password.value,
    };

    const result = Auth.register(data);
    if (result.success) {
      UI.showToast('Account created! Please sign in.', 'success');
      setTimeout(() => switchTab('login'), 1000);
    } else {
      UI.showToast(result.message, 'error');
    }
  }

  document.addEventListener('keydown', e => {
    if (e.key === 'Enter') {
      const active = document.querySelector('.auth-form.active').id;
      if (active === 'form-login') handleLogin();
      else handleRegister();
    }
  });
</script>
</body>
</html>
